{
  "name": "gsdf-eotf-video-adjuster",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "test": "node --test tests/*.test.mjs",
    "build": "vite build",
    "build:ext": "vite build && node scripts/buildExt.js",
    "smoke:ext": "node scripts/smokeExtensionChrome.mjs",
    "smoke:ext:env": "pwsh -NoProfile -ExecutionPolicy Bypass -Command \". './scripts/useChromeExtensionEnv.ps1' -Quiet; npm run smoke:ext\"",
    "preview": "vite preview",
    "clean": "node -e \"const fs = require('fs'); for (const path of ['dist', 'server.js']) fs.rmSync(path, { recursive: true, force: true });\"",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.2.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.4.2",
    "ws": "^8.21.0"
  }
}
