# GSDF EOTF Video Adjuster does not require cloud API keys.
# This file is a reference for local Chrome extension smoke-test variables.
# It is not auto-loaded by npm scripts; set these in PowerShell or dot-source
# scripts/useChromeExtensionEnv.ps1 before running npm run smoke:ext.

# Leave CHROME_PATH unset to let scripts/smokeExtensionChrome.mjs prefer the
# newest local Playwright Chromium. This is the recommended path on managed
# Windows machines where Google Chrome rejects --load-extension.
# CHROME_PATH="C:\Path\To\chromium\chrome.exe"

# Remote debugging port used by scripts/smokeExtensionChrome.mjs.
CHROME_DEBUG_PORT="9338"

# Optional URL to test instead of the built-in local smoke page.
# SMOKE_URL="http://127.0.0.1:3000/"

# Governed local Vite development server.
# Registered in DevGov as gsdf-eotf-video-adjuster/vite-dev.
VITE_DEV_HOST="127.0.0.1"
VITE_DEV_PORT="3101"
